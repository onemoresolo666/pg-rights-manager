# 1. АВТОМАТИЧЕСКИЙ РЕДИРЕКТ С HTTP НА HTTPS (ОБНОВЛЁННЫЙ ИБ-КОНТУР)
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;
    return 301 https://$host$request_uri;
}

# 2. ОСНОВНОЙ СЕРВЕР HTTPS (Порт 443)
server {
    listen 443 ssl;
    server_name _;

    # Пути к SSL-сертификатам безопасности
    ssl_certificate /etc/pki/tls/certs/pgrights.crt;
    ssl_certificate_key /etc/pki/tls/private/pgrights.key;

    # Современные стойкие протоколы шифрования
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # ГЛОБАЛЬНЫЙ ИБ-ЗАВОР: Защита от кликджекинга и принудительная кодировка UTF-8
    charset utf-8;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;

    # Папка с отполированным фронтендом панели
    root /var/www/pgrights_frontend;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # ПРОКСИРОВАНИЕ НА БЭКЕНД FASTAPI
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 60s;
        proxy_connect_timeout 60s;
    }



    # ================================================================= -->
    # ЖЕСТКАЯ ИЗОЛЯЦИЯ ДОКУМЕНТАЦИИ SWAGGER UI НА УРОВНЕ ВЕБ-СЕРВЕРА    -->
    # ================================================================= -->
    location /docs {
        # Разрешаем доступ строго для локального хоста самого сервера
        allow 127.0.0.1;
        allow ::1;
        
        # Намертво блокируем просмотр интерактивного API для внешнего мира
        deny all;

        # Пробрасываем санкционированный запрос дальше на бэкенд FastAPI
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ИЗОЛЯЦИЯ СКРЫТОЙ OPENAPI-СХЕМЫ БЭКЕНДА
    location /openapi.json {
        allow 127.0.0.1;
        allow ::1;
        deny all;
        
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
    }

} # ЗАКРЫТИЕ СЕРВЕРА (ПОРТ 443)


