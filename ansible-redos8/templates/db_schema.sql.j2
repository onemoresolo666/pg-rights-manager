-- Создаем правильный индекс с фильтром по активности
CREATE UNIQUE INDEX unique_server_connection ON registered_servers (host, port, dbname) WHERE (is_active = true);

--
-- Name: idx_audit_logs_time_brin; Type: INDEX; Schema: public; Owner: pgrights_core_admin
--

