-- 1. Создаем пользователя с правом управлять ТОЛЬКО ролями, но без прав суперпользователя
CREATE ROLE pgrights_core_admin WITH LOGIN PASSWORD '{{ core_admin_password }}' CREATEROLE;

-- 2. Создаем базу данных
CREATE DATABASE service_manager_db WITH OWNER pgrights_core_admin;

-- 3. Даем ему права владельца над служебной базой данных
ALTER DATABASE service_manager_db OWNER TO pgrights_core_admin;

-- Переключаемся на созданную базу данных для дальнейшего наката структуры
\c service_manager_db

-- Накатываем расширение триграмм
CREATE EXTENSION IF NOT EXISTS pg_trgm WITH SCHEMA public;
COMMENT ON EXTENSION pg_trgm IS 'text similarity measurement and index searching based on trigrams';

-- 1. ПЕРВЫМ ДЕЛОМ СОЗДАЕМ ТАБЛИЦУ ПОЛЬЗОВАТЕЛЕЙ (РОДИТЕЛЬСКИЙ ОБЪЕКТ)
CREATE TABLE IF NOT EXISTS public.panel_users (
    id SERIAL PRIMARY KEY,
    username VARCHAR(50) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    is_active BOOLEAN DEFAULT TRUE,
    role VARCHAR(20) NOT NULL
);

ALTER TABLE public.panel_users ALTER COLUMN role SET DEFAULT 'admin';

-- Назначаем владельцем нашего админа ядра (чтобы у FastAPI был к ней полный доступ)
ALTER TABLE public.panel_users OWNER TO pgrights_core_admin;



--
-- Name: audit_logs; Type: TABLE; Schema: public; Owner: pgrights_core_admin
--

CREATE TABLE public.audit_logs (
    log_id integer NOT NULL,
    "timestamp" timestamp without time zone DEFAULT CURRENT_TIMESTAMP,
    target_server character varying(50) NOT NULL,
    username character varying(63) NOT NULL,
    table_name character varying(255),
    action character varying(63) NOT NULL,
    privilege character varying(255) NOT NULL,
    status character varying(32) NOT NULL,
    error_message text,
    admin_username character varying(63)
);


ALTER TABLE public.audit_logs OWNER TO pgrights_core_admin;

--
-- Name: audit_logs_log_id_seq; Type: SEQUENCE; Schema: public; Owner: pgrights_core_admin
--

CREATE SEQUENCE public.audit_logs_log_id_seq
    AS integer
    START WITH 1
    INCREMENT BY 1
    NO MINVALUE
    NO MAXVALUE
    CACHE 1;


ALTER SEQUENCE public.audit_logs_log_id_seq OWNER TO pgrights_core_admin;

--
-- Name: audit_logs_log_id_seq; Type: SEQUENCE OWNED BY; Schema: public; Owner: pgrights_core_admin
--

ALTER SEQUENCE public.audit_logs_log_id_seq OWNED BY public.audit_logs.log_id;


--
-- Name: one_time_tokens; Type: TABLE; Schema: public; Owner: pgrights_core_admin
--

CREATE TABLE public.one_time_tokens (
    token_id uuid DEFAULT gen_random_uuid() NOT NULL,
    db_user character varying(65) NOT NULL,
    encrypted_password text NOT NULL,
    created_at timestamp without time zone DEFAULT CURRENT_TIMESTAMP,
    expires_at timestamp without time zone NOT NULL
);


ALTER TABLE public.one_time_tokens OWNER TO pgrights_core_admin;

