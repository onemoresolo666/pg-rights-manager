# Автоматически сгенерированный криптоустойчивый Fernet-ключ
MASTER_KEY={{ dynamic_master_key }}

# Доступы к служебной базе (права овнер service_manager_db)
SERVICE_DB_NAME=service_manager_db
SERVICE_DB_USER=pgrights_core_admin
SERVICE_DB_PASSWORD={{core_admin_password}}
SERVICE_DB_HOST=127.0.0.1
SERVICE_DB_PORT=5432

# Настройки почтового шлюза SMTP (Принудительный нижний регистр для флагов)
SMTP_HOST=127.0.0.1
SMTP_PORT=465
SMTP_USER=admin@local.me
SMTP_PASSWORD=changeme
SMTP_USE_TLS=true
